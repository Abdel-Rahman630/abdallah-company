{
  "info": {
    "_postman_id": "f2b2a350-2396-4abb-ae73-b3810fa5574e",
    "name": "AHCL Public CMS API",
    "description": "Public JSON APIs exposed by the AHCL Laravel CMS.\n\nNews, Events, and CMS Pages are public read-only endpoints. Contact Us provides one public submission endpoint. Public responses never expose dashboard state, local filesystem paths, or private inquiry data.\n\nResponse envelope (all endpoints):\n{\n  \"status\": true,\n  \"message\": \"...\",\n  \"meta\": { ... },\n  \"data\": { ... } | [ ... ]\n}\n\nLocalization:\nSend either a `lang` query parameter or an `Accept-Language` header. Supported values: `ar` (default) and `en`.\n\nCMS dashboard routes, including Contact Inquiries management, are browser-based, session-authenticated, and CSRF-protected. They are not token-authenticated API endpoints and are not documented as API requests in this collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "24272792",
    "_collection_link": "https://go.postman.co/collection/24272792-f2b2a350-2396-4abb-ae73-b3810fa5574e?source=collection_link"
  },
  "item": [
    {
      "name": "CMS Pages",
      "item": [
        {
          "name": "Show Page by Key",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/cms/pages/:key?lang=en",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "cms",
                "pages",
                ":key"
              ],
              "query": [
                {
                  "key": "lang",
                  "value": "en",
                  "description": "Optional locale: ar (default) or en."
                }
              ],
              "variable": [
                {
                  "key": "key",
                  "value": "home",
                  "description": "The stable page key. Replace with a key that exists in the cms_pages table."
                }
              ]
            },
            "description": "Returns a single active CMS page for the requested locale. Returns 404 when the page does not exist or is inactive."
          },
          "response": []
        }
      ],
      "description": "Public read-only CMS page content. Pages are managed in the CMS panel; this endpoint returns a page by its stable `key`. No pages are seeded by default, so a valid key must exist for a successful response."
    },
